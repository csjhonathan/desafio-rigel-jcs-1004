# Banco de dados
# Porta publicada no host (só muda o bind em localhost; dentro da rede Docker segue db:5432)
# Se já existe Postgres na 5432, use por exemplo: POSTGRES_HOST_PORT=5433
POSTGRES_HOST_PORT=5432
DATABASE_URL=postgresql://postgres:postgres@db:5432/rigel-jcs-1004

# JWT
JWT_SECRET=troque_em_producao
JWT_EXPIRES_IN=7d

# API do PJE
PJE_API_BASE_URL=https://comunicaapi.pje.jus.br/api/v1
PJE_LAST_DAYS_TO_SYNC=20
# Máximo de páginas PJE por dia no seed / syncLastDays (5 itens/página). Predefinido 10 = 50 comunicações/dia.
PJE_SYNC_MAX_PAGES_PER_DAY=10
# Quantos dias processar em paralelo no seed/syncLastDays (1–8; predefinido 1). Aumentar só se a API não devolver 429.
# PJE_SYNC_DAY_CONCURRENCY=2
# Opcional: milissegundos entre pedidos de página na sync (predefinido 800). Aumente se ainda receber 429.
# PJE_PAGE_DELAY_MS=1200

# IA
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# NextAuth
NEXTAUTH_SECRET=troque_em_producao
NEXTAUTH_URL=http://localhost:3000

# App
NODE_ENV=development
BACKEND_PORT=3001
FRONTEND_PORT=3000

# Docker: o seed NÃO corre na subida do backend (a sync PJE demora e o healthcheck falharia).
# Com o stack a correr: docker compose exec backend npm run seed

# Frontend → API (browser usa localhost; no Docker Compose, API_URL_INTERNAL aponta para o serviço backend)
NEXT_PUBLIC_API_URL=http://localhost:3001
# API_URL_INTERNAL=http://backend:3001
